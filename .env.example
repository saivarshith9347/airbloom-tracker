# ThingSpeak API Configuration
# Get your channel ID and API key from https://thingspeak.com
VITE_THINGSPEAK_CHANNEL_ID=
VITE_THINGSPEAK_API_KEY=

# Admin Authentication
# Username for admin login
VITE_ADMIN_USERNAME=
# SHA-256 hash of the admin password (use: echo -n "yourpassword" | shasum -a 256)
VITE_ADMIN_PASSWORD_HASH=

# Home Location Configuration
# Default home location for the map (latitude, longitude, and display name)
VITE_HOME_LATITUDE=28.6139
VITE_HOME_LONGITUDE=77.209
VITE_HOME_NAME=Home Base
