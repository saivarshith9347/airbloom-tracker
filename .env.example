# ============================================
# AirBloom Tracker - Environment Variables
# ============================================
# 
# IMPORTANT FOR PRODUCTION (Vercel):
# 1. Copy these variables to your Vercel project settings
# 2. Go to: Project Settings > Environment Variables
# 3. Add each variable with its value
# 4. Redeploy after adding variables
#
# All variables must be prefixed with VITE_ to be accessible
# in the frontend application
# ============================================

# ThingSpeak API Configuration
# Get these from your ThingSpeak account
VITE_THINGSPEAK_CHANNEL_ID=your_channel_id_here
VITE_THINGSPEAK_API_KEY=your_read_api_key_here

# Admin Authentication
# Username for admin login (without @domain)
VITE_ADMIN_USERNAME=admin

# Password Hash (SHA-256)
# Generate using: echo -n "your_password" | openssl dgst -sha256
# Or use online tool: https://emn178.github.io/online-tools/sha256.html
VITE_ADMIN_PASSWORD_HASH=your_sha256_hash_here

# Home Location Configuration
# Default coordinates for the map center
VITE_HOME_LATITUDE=28.6139
VITE_HOME_LONGITUDE=77.209
VITE_HOME_NAME=Home Base

# ============================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================
# 
# For Vercel:
# 1. ✓ Add all VITE_* variables in Vercel dashboard
# 2. ✓ Ensure no trailing spaces in values
# 3. ✓ Redeploy after adding/changing variables
# 4. ✓ Check build logs for environment variable warnings
# 5. ✓ Test login immediately after deployment
#
# For other platforms:
# - Ensure environment variables are set at build time
# - Variables must be available during the build process
# - Vite embeds these values at build time (not runtime)
# ============================================
